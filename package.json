{
  "name": "whatsapp-chatbot",
  "version": "1.0.0",
  "description": "A WhatsApp chatbot powered by LLM",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "setup": "tsx scripts/setup.ts",
    "db:init": "tsx scripts/dbInit.ts",
    "demo:seed": "tsx scripts/seedPersonas.ts",
    "demo:seed:clear": "tsx scripts/seedPersonas.ts --clear",
    "demo": "tsx scripts/demoConversation.ts",
    "demo:all": "tsx scripts/demoConversation.ts --all",
    "demo:onboarding": "tsx scripts/demoConversation.ts --onboarding",
    "eval:messages": "tsx scripts/evalMessages.ts",
    "eval:classify": "tsx scripts/evalClassification.ts",
    "eval:classify:offline": "tsx scripts/evalClassification.ts --offline",
    "eval:all": "pnpm run eval:messages && pnpm run eval:classify"
  },
  "keywords": [
    "whatsapp",
    "chatbot",
    "llm",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "openai": "^4.20.1",
    "pg": "^8.11.3",
    "puppeteer": "^24.30.0",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.23.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode-terminal": "^0.12.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
